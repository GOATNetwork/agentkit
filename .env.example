# Merchant gateway base URL
MERCHANT_API_BASE_URL=https://merchant.example.com

# Optional bearer token for merchant APIs
MERCHANT_API_KEY=

# Optional custom route paths
MERCHANT_CREATE_ORDER_PATH=/x402/create-order
MERCHANT_ORDER_STATUS_PATH=/x402/order-status/:paymentId
MERCHANT_SUBMIT_SIGNATURE_PATH=/x402/submit-signature
MERCHANT_CANCEL_ORDER_PATH=/x402/cancel-order

# x402 Merchant Portal API base URL (distinct from merchant gateway)
MERCHANT_PORTAL_BASE_URL=http://localhost:8080

# Idempotency store mode: memory | redis
AGENTKIT_IDEMPOTENCY_MODE=memory
# Used when AGENTKIT_IDEMPOTENCY_MODE=redis
AGENTKIT_REDIS_URL=redis://127.0.0.1:6379
